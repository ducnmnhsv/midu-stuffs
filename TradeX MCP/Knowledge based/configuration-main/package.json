{
  "name": "configuration",
  "version": "1.0.0",
  "description": "Configuration service of TradeX system ",
  "scripts": {
    "clean": "rimraf coverage build tmp",
    "build": "npm run fix && tsc -p tsconfig.json",
    "watch": "tsc -w -p tsconfig.json",
    "pretest": "npm run lint",
    "run-local": "cp src/env.js build/src/env.js && cd build/src && node index.js",
    "build-local": "npm run build && npm run run-local",
    "start": "npm run build && node build/src/index.js",
    "check": "eslint . --ext .ts",
    "fix": "eslint src/**/*.ts --fix",
    "compile": "tsc -p ."
  },
  "author": "admin@difisoft.vn",
  "license": "ISC",
  "dependencies": {
    "ajv": "^8.12.0",
    "aws-sdk": "^2.1536.0",
    "axios": "^1.6.5",
    "form-data": "^4.0.0",
    "minio": "^7.1.3",
    "mysql": "^2.18.1",
    "reflect-metadata": "^0.2.1",
    "swagger-parser": "^10.0.3",
    "tradex-common": "git+https://github.com/difisoft/tradex-common-16.16.0.git",
    "tradex-models-configuration": "git+https://github.com/difisoft/tradex-models-configuration-ts.git",
    "tradex-models-configuration-validator": "git+https://github.com/difisoft/tradex-models-configuration-validator-ts.git",
    "tradex-models-ts": "git+https://github.com/difisoft/tradex-models-ts.git",
    "typedi": "^0.10.0",
    "typeorm": "^0.3.19",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^16.11.7",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^8.0.3",
    "prettier": "^3.2.2",
    "rimraf": "^5.0.5",
    "tslib": "^2.6.2",
    "tsutils": "^3.21.0",
    "typescript": "^5.3.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run fix && npm run check"
    }
  },
  "bin": "build/src/index.js"
}
