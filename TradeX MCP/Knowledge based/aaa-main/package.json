{
  "name": "aaa",
  "version": "1.0.0",
  "description": "authentication and authorization server follow oauth2 specificatin",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf build && mkdir build",
    "testjs": "babel-node src/test.js",
    "start": "tsc -w -p tsconfig.json",
    "copyKeys": "mkdir -p build/src/keys && cp -R ../tradex-key/dev/aaa build/src/keys/aaa",
    "run-local": "cp src/env.js build/src/env.js && npm run copyKeys && cd build/src && node index.js",
    "build": "npm run clean && tsc -p tsconfig.json",
    "build-local": "npm run build && npm run run-local",
    "utest": "node --version | grep v1[0-9]* && tsc -p . && mocha build/src/tests/*.test.js #require node 10x+"
  },
  "author": "tuanhiep1232",
  "license": "UNLICENSED",
  "dependencies": {
    "@types/bcrypt-nodejs": "0.0.30",
    "@types/jsonwebtoken": "^7.2.8",
    "@types/mysql": "^2.15.0",
    "@types/node-zookeeper-client": "^0.2.6",
    "@types/uuid": "^3.2.1",
    "apache-crypt": "^1.2.6",
    "fetch": "^1.1.0",
    "fetch-to-curl": "^0.5.2",
    "jsonwebtoken": "^8.3.0",
    "moment": "^2.22.1",
    "mysql": "^2.16.0",
    "nanomatch": "^1.2.13",
    "node-fetch": "^2.7.0",
    "node-schedule": "^1.3.2",
    "node-zookeeper-client": "^0.2.2",
    "otp-generator": "^1.1.0",
    "rx": "^4.1.0",
    "rx-node": "^1.0.2",
    "tradex-common": "git+https://github.com/difisoft/tradex-common-16.16.0.git",
    "uuid": "^3.3.2",
    "typedi": "^0.8.0",
    "redis": "^3.0.2"
  },
  "devDependencies": {
    "@types/mocha": "^9.1.0",
    "@types/node": "^10.7.1",
    "@typescript-eslint/eslint-plugin": "^6.7.2",
    "@typescript-eslint/parser": "^6.7.2",
    "eslint": "^8.50.0",
    "pkg": "^5.8.1",
    "prettier": "^3.0.3",
    "rimraf": "^2.6.2",
    "tsutils": "^3.21.0",
    "typescript": "^5.2.2"
  },
  "resolutions": {},
  "bin": "build/src/index.js",
  "pkg": {
    "assets": [],
    "options": [
      "experimental-modules"
    ],
    "targets": [
      "node16-alpine-x64"
    ],
    "output": "dist/entrypoint"
  }
}
