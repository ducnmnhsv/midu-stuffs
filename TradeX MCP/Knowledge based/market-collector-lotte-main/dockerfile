# Multi-stage build for Market Collector Lotte (Java Spring Boot Application)
FROM maven:3.9.5-eclipse-temurin-17 AS builder

# Set working directory
WORKDIR /app

# Copy pom.xml first for better layer caching
COPY pom.xml .

# Download dependencies (this layer will be cached if pom.xml doesn't change)
RUN mvn dependency:go-offline -B

# Copy source code
COPY src ./src

# Build the application
RUN mvn clean package -DskipTests

# Production stage
FROM eclipse-temurin:17-jdk AS production

# Install necessary packages for production
RUN apt-get update && apt-get install -y \
    bash \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Create app user for security
RUN groupadd -r appuser && useradd -r -g appuser appuser

# Set working directory
WORKDIR /app

# Copy the built JAR from builder stage
COPY --from=builder /app/target/market-collector-lotte-1.0.jar ./app.jar

# Copy entrypoint script
COPY entrypoint.sh ./entrypoint.sh

# Make entrypoint script executable
RUN chmod +x ./entrypoint.sh

# Create logs directory
RUN mkdir -p /logs && chown -R appuser:appuser /logs

# Create app environment directory structure
RUN mkdir -p /appEnv/services/deployment-resources && \
    chown -R appuser:appuser /appEnv

# Switch to app user
USER appuser

# Expose port (if needed for health checks)
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8080/actuator/health || exit 1

# Use entrypoint.sh instead of dumb-init as requested
ENTRYPOINT ["/bin/bash", "./entrypoint.sh", "java -jar app.jar"]
