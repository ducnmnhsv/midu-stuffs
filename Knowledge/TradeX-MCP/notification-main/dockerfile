# Multi-stage build for Notification Service (Java Spring Boot Application)
FROM oracle/serverjre:8 AS builder

# Install Maven
RUN yum update -y && yum install -y \
    wget \
    tar \
    gzip \
    && yum clean all

# Download and install Maven
RUN wget https://archive.apache.org/dist/maven/maven-3/3.8.6/binaries/apache-maven-3.8.6-bin.tar.gz \
    && tar -xzf apache-maven-3.8.6-bin.tar.gz \
    && mv apache-maven-3.8.6 /opt/maven \
    && rm apache-maven-3.8.6-bin.tar.gz

# Set Maven environment variables
ENV MAVEN_HOME=/opt/maven
ENV PATH=$PATH:$MAVEN_HOME/bin

# Set working directory
WORKDIR /app

# Copy pom.xml first for better layer caching
COPY pom.xml .

# Download dependencies (this layer will be cached if pom.xml doesn't change)
RUN mvn dependency:go-offline -B

# Copy source code
COPY src ./src

# Build the application
RUN mvn clean package -DskipTests

# Production stage
FROM oracle/serverjre:8 AS production

# Install necessary packages for production
RUN yum update -y && yum install -y \
    bash \
    curl \
    && yum clean all

# Create app user for security
RUN groupadd -g 1000 appuser && useradd -r -s /bin/bash -u 1000 -g appuser appuser

# Set working directory
WORKDIR /app

# Copy the built JAR from builder stage
COPY --from=builder /app/target/notification-1.0-SNAPSHOT.jar ./app.jar

# Copy entrypoint script
COPY entrypoint.sh ./entrypoint.sh

# Make entrypoint script executable
RUN chmod +x ./entrypoint.sh

# Create logs directory
RUN mkdir -p /logs && chown -R appuser:appuser /logs

# Create app environment directory structure
RUN mkdir -p /appEnv/services/deployment-resources && \
    chown -R appuser:appuser /appEnv

# Switch to app user
USER appuser

# Expose port (if needed for health checks)
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
    CMD curl -f http://localhost:8080/actuator/health || exit 1

# Use entrypoint.sh instead of dumb-init as requested
ENTRYPOINT ["/bin/bash", "./entrypoint.sh", "java -jar app.jar"]
