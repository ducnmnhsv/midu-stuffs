{
  "name": "rest-proxy",
  "version": "1.0.0",
  "description": "Rest Proxy Server For TradeX System",
  "scripts": {
    "build": "npm run compile",
    "build-local": "npm run build && cp src/env.js build/src/env.js && cd build/src && node index.js",
    "run-local": "npm run copyResource && cp src/env.js build/src/env.js && cd build/src && node index.js",
    "watch": "tsc -w -p tsconfig.json",
    "start": "npm run build && node build/src/server.js",
    "compile": "tsc -p tsconfig.json",
    "lint": "npx eslint src/**/*.ts --fix"
  },
  "author": "admin@difisoft.com",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^1.18.2",
    "cors": "^2.8.4",
    "express": "^4.16.3",
    "express-device": "^0.4.2",
    "fs": "0.0.1-security",
    "http-proxy-middleware": "^2.0.6",
    "jsonwebtoken": "^9.0.2",
    "openapi-types": "^1.3.5",
    "tradex-common": "git+https://github.com/difisoft/tradex-common-16.16.0.git",
    "tslib": "^1.14.1",
    "typedi": "^0.8.0",
    "uuid": "^3.2.1"
  },
  "devDependencies": {
    "@types/body-parser": "^1.17.0",
    "@types/cors": "^2.8.4",
    "@types/express": "^4.16.0",
    "@types/jsonwebtoken": "^7.2.8",
    "@types/node": "^10.17.11",
    "@types/uuid": "^3.4.3",
    "@typescript-eslint/eslint-plugin": "^6.18.0",
    "@typescript-eslint/parser": "^6.18.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "prettier": "^3.1.1",
    "rimraf": "^2.6.2",
    "tsutils": "^3.21.0",
    "typescript": "^5.3.3"
  },
  "bin": "build/src/index.js",
  "pkg": {
    "assets": [],
    "targets": [
      "node16-alpine-x64"
    ],
    "output": "dist/entrypoint"
  }
}
