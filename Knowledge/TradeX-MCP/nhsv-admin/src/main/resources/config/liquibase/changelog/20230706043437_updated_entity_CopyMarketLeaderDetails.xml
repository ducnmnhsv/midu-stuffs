<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!--
        Dropped columns to the entity CopyMarketLeaderDetails.
    -->
    <changeSet id="20230706043437-1-drop-columns" author="jhipster">
        <dropColumn tableName="t_copy_market_leader_details">
            <column name="total_sub"/>
        </dropColumn>
    </changeSet>

    <changeSet id="20230706043746-1-add-columns" author="jhipster">
        <addColumn tableName="t_copy_market_leader_details">
            <column name="type" type="varchar(255)"/>
            <column name="label" type="varchar(255)"/>
            <column name="jhi_key" type="varchar(255)"/>
            <column name="value" type="varchar(2000)"/>
        </addColumn>
    </changeSet>

    <changeSet id="20230706043746-fields-constraints" author="jhipster">
        <addNotNullConstraint tableName="t_copy_market_leader_details"
                              columnName="type"
                              columnDataType="varchar(255)"/>
        <addNotNullConstraint tableName="t_copy_market_leader_details"
                              columnName="label"
                              columnDataType="varchar(255)"/>
        <addNotNullConstraint tableName="t_copy_market_leader_details"
                              columnName="jhi_key"
                              columnDataType="varchar(255)"/>
        <addNotNullConstraint tableName="t_copy_market_leader_details"
                              columnName="value"
                              columnDataType="varchar(2000)"/>
    </changeSet>

    <changeSet id="20230706043746-columns-faker" author="jhipster" context="faker">
        <!--
            Load sample data generated with Faker.js
            - This data can be easily edited using a CSV editor (or even MS Excel) and
              is located in the 'src/main/resources/config/liquibase/fake-data' directory
            - By default this data is applied when running with the JHipster 'dev' profile.
              This can be customized by adding or removing 'faker' in the 'spring.liquibase.contexts'
              Spring Boot configuration key.
        -->
        <loadUpdateData
            file="config/liquibase/fake-data/20230706043746_entity_copy_market_leader_details.csv"
            separator=";"
            onlyUpdate="true"
            primaryKey="id"
            tableName="t_copy_market_leader_details">
            <column name="id" type="numeric"/>
            <column name="type" type="string"/>
            <column name="label" type="string"/>
            <column name="jhi_key" type="string"/>
            <column name="value" type="string"/>
            <!-- jhipster-needle-liquibase-add-loadcolumn - JHipster (and/or extensions) can add load columns here -->
        </loadUpdateData>
    </changeSet>

    <!-- jhipster-needle-liquibase-add-changeset - JHipster will add changesets here -->

</databaseChangeLog>
