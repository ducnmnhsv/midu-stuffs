<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
    xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
    xmlns:ext="http://www.liquibase.org/xml/ns/dbchangelog-ext"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd
                        http://www.liquibase.org/xml/ns/dbchangelog-ext http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-ext.xsd">

    <!--
        Added the entity InviteUser.
    -->
    <changeSet id="20230627094323-1" author="jhipster">
        <createTable tableName="t_invite_user">
            <column name="id" type="bigint">
                <constraints primaryKey="true" nullable="false" />
            </column>
            <column name="login" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="email" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="status" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="created_at" type="${datetimeType}">
                <constraints nullable="true" />
            </column>
            <column name="updated_at" type="${datetimeType}">
                <constraints nullable="true" />
            </column>
            <column name="created_id" type="bigint">
                <constraints nullable="true" />
            </column>
            <column name="created_by" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="activation_key" type="varchar(255)">
                <constraints nullable="true" />
            </column>
            <column name="activation_date" type="${datetimeType}">
                <constraints nullable="true" />
            </column>
            <!-- jhipster-needle-liquibase-add-column - JHipster will add columns here -->
        </createTable>
        <dropDefaultValue tableName="t_invite_user" columnName="created_at"
            columnDataType="${datetimeType}" />
        <dropDefaultValue tableName="t_invite_user" columnName="updated_at"
            columnDataType="${datetimeType}" />
        <dropDefaultValue tableName="t_invite_user" columnName="activation_date"
            columnDataType="${datetimeType}" />
    </changeSet>
    <changeSet id="20230627094323-2" author="Manh">
        <addAutoIncrement
            columnName="id"
            columnDataType="bigint"
            tableName="t_invite_user" />
    </changeSet>
    <changeSet id="20230627094323-3" author="Manh">
        <addColumn tableName="t_invite_user">
            <column name="authorities" type="varchar(255)">
                <constraints nullable="false" />
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>