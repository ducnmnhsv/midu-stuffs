{
  "name": "lotte-bridge",
  "version": "1.0.0",
  "description": "Lotte Rest Client Service",
  "scripts": {
    "clean": "rimraf coverage build tmp",
    "build": "export NODE_OPTIONS='--max-old-space-size=4096' && npm run pretest",
    "watch": "tsc -w -p tsconfig.json",
    "lint": "tslint -t stylish --project \"tsconfig.json\"",
    "pretest": "npm run fix && npm run check && npm run compile",
    "start": "npm run build && node build/src/index.js",
    "run-local": "cd build/src && node index.js",
    "build-local": "npm run compile && npm run run-local",
    "check": "gts check",
    "compile": "tsc -p .",
    "fix": "gts fix",
    "test": "echo \"Error: no test specified\" && exit 1",
    "unittest": "npm run compile && npx mocha build/src/**/*_test.js"
  },
  "author": "hiepnguyen@difisoft.com",
  "license": "ISC",
  "devDependencies": {
    "@types/btoa": "^1.2.3",
    "@types/mocha": "^8.2.0",
    "@types/node": "^14.6.0",
    "@types/node-fetch": "^2.5.4",
    "@types/node-schedule": "^1.2.4",
    "@types/uuid": "^9.0.4",
    "gts": "^1.1.2",
    "husky": "^1.3.1",
    "prettier": "^2.1.1",
    "tslint": "^5.20.1",
    "tslint-microsoft-contrib": "^5.2.0",
    "typescript": "^4.0.2"
  },
  "dependencies": {
    "axios": "^0.21.4",
    "btoa": "^1.2.1",
    "fetch-to-curl": "^0.4.0",
    "minio": "^7.0.18",
    "moment": "^2.29.4",
    "mysql": "^2.18.1",
    "node-fetch": "^2.6.0",
    "node-schedule": "^1.3.2",
    "r2curl": "^0.2.4",
    "redis": "^3.0.2",
    "reflect-metadata": "^0.1.13",
    "tradex-common": "git+https://github.com/difisoft/tradex-common-10.16.3.git",
    "typedi": "^0.8.0",
    "typeorm": "^0.2.29",
    "typeorm-typedi-extensions": "^0.2.3",
    "uuid": "^9.0.1",
    "zlib": "^1.0.5",
    "apache-crypt": "^1.2.6"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run fix && npm run check"
    }
  },
  "overrides": {
    "tradex-common": {
      "log4js": "3.0.6"
    }
  },
  "bin": "build/src/index.js"
}
